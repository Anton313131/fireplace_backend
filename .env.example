PORT=3000
NODE_ENV=development

DATABASE_URL=postgres://user:password@localhost:5432/flora

# Comma-separated list of allowed origins. Production: single storefront origin.
CORS_ORIGIN=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# Bearer key required for write operations (POST/PUT/PATCH/DELETE). Read endpoints stay public.
ADMIN_API_KEY=replace-with-long-random-string

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=flora-bouquets

# Required by `npm run seed`: path to the storefront img/ directory.
SEED_IMAGES_DIR=
