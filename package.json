{
  "name": "flora-bouquet-backend",
  "version": "0.1.0",
  "description": "Flora Bouquet catalogue backend: Express + Sequelize + PostgreSQL.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
